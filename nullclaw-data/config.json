{
	"models": {
		"providers": {
			"openrouter": {
				"api_key": "$OPENROUTER_API_KEY"
			}
		}
	},
	"agents": {
		"defaults": {
			"model": {
				"primary": "openrouter/google/gemini-3.1-flash-preview"
			}
		}
	},
	"mcp": {
		"server": "http://news-mcp:8888"
	},
	"channels": {
		"telegram": {
			"accounts": {
				"default": {
					"bot_token": "$TELEGRAM_API_KEY",
					"allow_from": ["$TELEGRAM_USER_ID"],
					"reply_in_private": true
				}
			}
		}
	},
	"gateway": {
		"host": "127.0.0.1",
		"port": 3000,
		"require_pairing": true,
		"allow_public_bind": false
	},
	"autonomy": {
		"level": "supervised",
		"workspace_only": true,
		"max_actions_per_hour": 60
	},
	"security": {
		"sandbox": { "backend": "auto" },
		"audit": { "enabled": true, "retention_days": 90 }
	}
}
